---
import '../styles/global.css';
import { url } from '../lib/paths';
const { title = 'Memorial de Ivo Amandio Wittmann', description = 'Memorial de Ivo Amandio Wittmann: histórias, fotos, mensagens e lembranças reunidas com carinho.' } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()} />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href={url('/')}>Ivo Amandio Wittmann</a>
        <nav class="nav-links" aria-label="Navegação principal">
          <a href={url('/ivo')}>Memorial</a>
          <a href={url('/ivo/fotos')}>Fotos</a>
          <a href={url('/ivo/livro-de-visitas')}>Livro de visitas</a>
          <a href={url('/qr/ivo')}>QR</a>
          <a href={url('/enviar')}>Enviar memória</a>
          <a href={url('/sobre')}>Sobre</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="container">Memorial de Ivo Amandio Wittmann · espaço público, discreto e revisado manualmente antes de publicar novas contribuições.</div>
    </footer>
  </body>
</html>
