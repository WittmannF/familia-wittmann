---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/paths';
---
<BaseLayout title="Memorial de Ivo Amandio Wittmann">
  <section class="container hero content">
    <div class="eyebrow">Página reorganizada</div>
    <h1>O site agora é o memorial do Ivo</h1>
    <p class="lead">Esta página existia na versão mais ampla do projeto. Para simplificar, o conteúdo público foi concentrado no memorial de Ivo Amandio Wittmann.</p>
    <p><a class="button" href={url('/ivo')}>Ir para o memorial</a></p>
  </section>
</BaseLayout>
