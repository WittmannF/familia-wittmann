---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA';
---
<BaseLayout title="Enviar memória — Família Wittmann">
<section class="container hero"><div class="eyebrow">Contribuições revisadas</div><h1>Enviar memória</h1><p class="lead">Envie uma mensagem, memória escrita, foto, áudio ou vídeo. Nada será publicado automaticamente; todo material será revisado pela família antes de aparecer no site.</p><div class="notice"><strong>Se preferir, você também pode enviar pelo WhatsApp.</strong><br/><a href="https://wa.me/5519987211302?text=Oi%20Fernando%2C%20quero%20enviar%20uma%20mem%C3%B3ria%20para%20o%20site%20da%20Fam%C3%ADlia%20Wittmann.">Enviar pelo WhatsApp: (19) 98721-1302</a></div></section>
<section class="container section"><form class="card form" id="submission-form" action="/api/submit" method="post" enctype="multipart/form-data">
<div class="grid grid-2"><div class="field"><label>Nome<input name="name" required autocomplete="name"/></label></div><div class="field"><label>E-mail ou WhatsApp<input name="contact" required/></label></div></div>
<div class="grid grid-2"><div class="field"><label>Pessoa relacionada<select name="related_person"><option>Ivo Wittmann</option><option>Família Wittmann</option><option>Outro membro da família</option></select></label></div><div class="field"><label>Tipo de contribuição<select name="contribution_type" required><option>Livro de visitas</option><option>Memória escrita</option><option>Foto</option><option>Áudio</option><option>Vídeo</option><option>Documento antigo</option><option>Outro</option></select></label></div></div>
<div class="field"><label>Mensagem/contexto<textarea name="message" rows="7" required></textarea></label></div>
<div class="grid grid-2"><div class="field"><label>Data aproximada da lembrança<input name="memory_date" placeholder="Ex.: anos 1980, Natal de 1995..."/></label></div><div class="field"><label>Local aproximado<input name="location"/></label></div></div>
<div class="field"><label>Quem aparece na foto/vídeo?<input name="people_in_media"/></label></div>
<div class="grid grid-2"><div class="field"><label>Autorizo publicar no site?<select name="permission_to_publish" required><option value="sim">Sim</option><option value="nao">Não</option></select></label></div><div class="field"><label>Quero que meu nome apareça?<select name="show_author_name" required><option value="sim">Sim</option><option value="nao">Não</option></select></label></div></div>
<div class="field"><label>Observações privadas para a família<textarea name="private_notes" rows="4"></textarea></label></div>
<div class="field"><label>Upload de arquivo<input name="file" type="file" accept=".jpg,.jpeg,.png,.webp,.mp3,.m4a,.wav,.ogg,.mp4,.mov,.webm"/></label><p class="help">Limites: fotos até 20 MB; áudios até 50 MB; vídeos até 80 MB. Para vídeos maiores, envie pelo WhatsApp ou por link de Google Drive. Por segurança, não aceitamos SVG, HTML, ZIP, executáveis ou arquivos desconhecidos.</p></div>
<div class="cf-turnstile" data-sitekey={siteKey}></div>
<button class="button" type="submit">Enviar contribuição</button><p class="help" id="form-status" role="status"></p>
</form></section>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>
<script>
const form = document.getElementById('submission-form');
const statusEl = document.getElementById('form-status');
if (form instanceof HTMLFormElement && statusEl) {
  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    statusEl.textContent = 'Enviando...';
    try {
      const response = await fetch(form.action, { method: 'POST', body: new FormData(form) });
      const data = await response.json().catch(() => ({}));
      const message = data && typeof data === 'object' && 'message' in data && typeof data.message === 'string' ? data.message : 'Não foi possível enviar agora.';
      if (!response.ok) throw new Error(message);
      form.reset();
      statusEl.textContent = 'Recebemos sua contribuição. Obrigado! Ela será revisada antes de qualquer publicação.';
    } catch (error) {
      statusEl.textContent = error instanceof Error ? error.message : 'Erro no envio. Tente novamente ou envie pelo WhatsApp.';
    }
  });
}
</script>
</BaseLayout>
