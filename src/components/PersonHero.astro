---
import { url } from '../lib/paths';
const { person } = Astro.props;
---
<section class="container hero person-hero">
  <div class="portrait"><img src={url(person.data.cover_image)} alt={`Foto de ${person.data.name}`} /></div>
  <div>
    <div class="eyebrow">Memorial</div>
    <h1>{person.data.full_name}</h1>
    <p class="dates">{person.data.birth_date || 'Nascimento a confirmar'} — {person.data.death_date || 'Falecimento a confirmar'}</p>
    <div class="content"><slot /></div>
  </div>
</section>
